# Domain your app is served from (compose/Caddy) — e.g. bridge.example.com
# Not needed for local dev (see DEV_AUTH below).
DOMAIN=

# Google OAuth credentials — see README "Google sign-in setup"
# Not needed for local dev (see DEV_AUTH below).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Local dev only (leave unset in a real deployment) ---
# Uncomment to skip Google OAuth and use name-only login:
# DEV_AUTH=1
# Uncomment to set the app's own base URL (defaults to https://$DOMAIN):
# BASE_URL=http://localhost:3000
