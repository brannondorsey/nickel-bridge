{
  "name": "bridge-bot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "server",
    "web"
  ],
  "scripts": {
    "build": "npm run build -w @bridge/core -w @bridge/ai -w server -w web",
    "dev": "npm run dev -w server",
    "test": "npm run test -w @bridge/core -w @bridge/ai -w server --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "playwright": "^1.61.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
